<configuration>

  <import
    class="ch.qos.logback.classic.jul.LevelChangePropagator" />
  <contextListener class="LevelChangePropagator">
    <resetJUL>true</resetJUL>
  </contextListener>

  <appender name="STDOUT"
    class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <appender name="ROLL_FILE"
    class="ch.qos.logback.core.rolling.RollingFileAppender">
    <!-- Every root event is written twice (STDOUT + here), but only STDOUT is captured
         into the TCK group logs the reports parse. Set DAANSE_LOG_FILE=OFF to drop this
         second write path for a run. -->
    <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
      <level>${DAANSE_LOG_FILE:-TRACE}</level>
    </filter>
    <file>log/log.log</file>
    <rollingPolicy
      class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>log/log.log-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <!-- each archived file's size will be max 10MB -->
      <maxFileSize>10MB</maxFileSize>
      <!-- 30 days to keep -->
      <maxHistory>30</maxHistory>
      <!-- total size of all archive files, if total size > 100MB, it will
      delete old archived file -->
      <totalSizeCap>100MB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <logger name="org.eclipse.jetty" level="WARN"/>
  <logger name="com.github.dockerjava.zerodep.shaded.org.apache.hc.client5" level="WARN"/>

  <!-- TCK runs at INFO to keep logs small and fast. The per-SQL DEBUG firehose
       logged every statement ~3x and produced multi-GB logs. We KEEP the actual
       SQL visible via RolapUtil at DEBUG ("SqlStatement: executing sql [...]"),
       but silence the redundant terse/event-object loggers that dumped the same
       statements again (the LoggingEventBus event objects were the biggest
       hog). Test pass/fail + assertion diagnostics come from the bnd tester
       stdout, not logback. -->
  <logger name="org.eclipse.daanse.rolap.common.RolapUtil" level="DEBUG"/>
  <logger name="daanse.sql" level="WARN"/>
  <!-- Statement-generation "why/how it was built" trace. Kept at TRACE (always on): build-decision lines
       + per-column detail + builder OLD/NEW SQL. The one expensive part — SqlSelectQuery rebuilding the
       legacy SQL to compare — is NOT driven by this level; it is gated by -Ddaanse.sql.gen.legacycompare=true
       so always-on TRACE stays cheap. Override with DAANSE_LOG_SQLGEN to measure what the trace costs. -->
  <logger name="daanse.sql.gen" level="${DAANSE_LOG_SQLGEN:-TRACE}"/>
  <logger name="org.eclipse.daanse.olap.core.LoggingEventBus" level="WARN"/>
  <logger name="org.eclipse.daanse.sql.dialect.db.common.AbstractJdbcDialect" level="WARN"/>

  <root level="INFO">
    <appender-ref ref="STDOUT" />
    <appender-ref ref="ROLL_FILE" />
  </root>
</configuration>