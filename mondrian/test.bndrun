-runstartlevel: \
    order=sortbynameversion,\
    begin=-1

-runtrace: true

-tester: biz.aQute.tester.junit-platform


-runsystemcapabilities: ${native_capability}

-runproperties: logback.configurationFile=${project.basedir}/logback.xml

# Force the test JVM default locale to en_US at startup so currency/number
# formatting is deterministic ($ not £). Must be a -runvm (JVM launch) arg, not
# -runproperties: java.util.Locale's default is computed at JVM init from these,
# and Format.java caches the currency symbol from Locale.getDefault() at first
# use (never cleared), so MondrianRuntimeExtension's later setDefault is too late.
-runvm.locale: -Duser.language=en, -Duser.country=US

-runfw: org.apache.felix.framework

-runee: JavaSE-25

-runrequires: \
	bnd.identity;id='${project.artifactId}-tests',\
	bnd.identity;id=junit-jupiter-engine,\
	bnd.identity;id=junit-platform-launcher,\
	bnd.identity;id='org.glassfish.hk2.osgi-resource-locator',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.api',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.impl',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.dialect.db.mysql',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.dialect.db.h2',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.dialect.db.sqlite',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.dialect.db.derby',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.dialect.db.mariadb',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.dialect.db.postgresql',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.dialect.db.oracle',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.dialect.db.mssqlserver',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.dialect.db.clickhouse',\
	bnd.identity;id='org.eclipse.daanse.jdbc.db.dialect.db.duckdb',\
	bnd.identity;id='derby',\
	bnd.identity;id='org.duckdb.duckdb_jdbc',\
	bnd.identity;id='mariadb-java-client',\
	bnd.identity;id='org.postgresql.jdbc',\
	bnd.identity;id='com.microsoft.sqlserver.mssql-jdbc',\
	bnd.identity;id='com.github.ben-manes.caffeine',\
	bnd.identity;id='org.apache.aries.spifly.dynamic.bundle',\
	bnd.identity;id='org.eclipse.daanse.sql.statement.api',\
	bnd.identity;id='org.eclipse.daanse.sql.statement.impl',\
	bnd.identity;id='org.eclipse.daanse.jdbc.datasource.oracle',\
	bnd.identity;id='org.eclipse.daanse.jdbc.datasource.clickhouse'



# No tester.names filter — all @Testable classes in the test fragment run.
# If you want to pin a single test, set:
#   -runproperties.tester: tester.names='mondrian.test.PerformanceTest'
# (kept commented; leave commented for full-suite runs.)


# -runbundles is calculated by the bnd-resolver-maven-plugin


